

FROM node:20-slim

WORKDIR /app

# Dependências nativas para build e runtime
RUN apt-get update && apt-get install -y python3 make g++ gcc build-essential libsqlite3-dev

COPY package.json pnpm-lock.yaml ./
RUN corepack enable && corepack prepare pnpm@latest --activate
RUN pnpm install --frozen-lockfile

COPY . .
ENV NODE_OPTIONS=--max-old-space-size=4096
RUN pnpm build

ENV NODE_ENV=production
ENV NUXT_PORT=3000
EXPOSE 3000

CMD ["pnpm", "start"]
